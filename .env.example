# LightRAG 知识库服务地址，用于后续入库请求。
LIGHTRAG_SERVER_URL=http://localhost:9621

# MinerU 解析服务地址，PDF 请求解析会调用该服务的 /file_parse 接口。
MINERU_SERVER_URL=http://localhost:8000

# MySQL 数据库连接配置。
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# 原始文件扫描目录，支持绝对路径或相对路径。
SCAN_INPUT_PATH=./data/input

# 解析结果输出目录，PDF markdown 和解析结果 JSON 会保存到这里。
PARSE_OUTPUT_PATH=./output

# 忽略扫描的文件类型，多个类型用英文逗号分隔，不区分大小写，例如：pdf,docx。
IGNORE_FILE_TYPES=

# 是否开启日志记录，支持 true/false、yes/no、on/off、1/0。
ENABLE_LOGGING=true

# 同时并发执行的解析请求批次数量。
PARSE_REQUEST_CONCURRENCY=3

# 单次 /file_parse 请求中携带的 PDF 文件数量。
PARSE_REQUEST_BATCH_SIZE=2
