# LightRAG 知识库服务地址，用于后续入库请求。
LIGHTRAG_SERVER_URL=

# MinerU 解析服务地址，PDF 请求解析会调用该服务的 /file_parse 接口。
MINERU_SERVER_URL=

# MySQL 数据库连接配置。
DB_HOST=
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=

# SSH 配置
SSH_HOST=
SSH_PORT=
SSH_USER=
SSH_PASSWORD=
SSH_TIMEOUT=10
SCAN_BATCH_SIZE=1000

# MARKDOWN 文件保存路径
MARKDOWN_OUTPUT_PATH="./markdown"
# MARKDOWN 图片保存路径
MARKDOWN_IMAGE_PATH="./images"
# 是否保留 markdown 文本
KEEP_MARKDOWN_FILE=true

# 同时并发执行的解析请求批次数量。
PARSE_REQUEST_CONCURRENCY=2
# 单次 /file_parse 请求中携带的文件数量。
PARSE_REQUEST_BATCH_SIZE=2
# /file_parse 请求超时时长，单位：秒，默认 5 分钟。
PARSE_REQUEST_TIMEOUT_SECONDS=600
# 解析任务每轮从 rag_files 中取出的待解析文件数量。
PARSE_TASK_BATCH_SIZE=5
# 解析任务轮询数据库的间隔，单位：秒。
PARSE_TASK_POLL_INTERVAL_SECONDS=10

# 是否开启日志记录，支持 true/false、yes/no、on/off、1/0。
ENABLE_LOGGING=true
# 清洗任务每个进程每次从 rag_files 领取的数据量。
CLEAN_TASK_BATCH_SIZE=5
# 清洗任务同时启动的进程数量。
CLEAN_TASK_WORKER_PROCESSES=2
# clean_status=1 超过该秒数未更新时，认为是上次异常中断遗留任务，可恢复重试。
CLEAN_TASK_STALE_SECONDS=3600