# MinerU 解析服务地址，解析模块会调用 {MINERU_SERVER_URL}/file_parse
MINERU_SERVER_URL=http://localhost:8000

# MySQL 数据库连接配置
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# 群晖 NAS SSH 配置，只用于读取文件和上传给 MinerU，不会修改 NAS 文件
SSH_HOST=
SSH_PORT=22
SSH_USER=
SSH_PASSWORD=
SSH_TIMEOUT=10

# 扫描模块每批从 nas_files 读取的记录数
SCAN_BATCH_SIZE=1000

# MinerU 解析后的 markdown 保存目录，文件名使用 rag_files.file_hash.md
MARKDOWN_OUTPUT_PATH=./markdown

# MinerU 返回的 base64 图片保存目录，会按 rag_files.id 创建子目录
MARKDOWN_IMAGE_PATH=./images

# 同时并发执行的 MinerU 请求批次数
PARSE_REQUEST_CONCURRENCY=2

# 单次 /file_parse 请求携带的文件数
PARSE_REQUEST_BATCH_SIZE=2

# /file_parse 请求超时时间，单位：秒
PARSE_REQUEST_TIMEOUT_SECONDS=600

# 每轮从 rag_files 领取 parse_status = 0 的任务数
PARSE_TASK_BATCH_SIZE=5

# 是否开启日志
ENABLE_LOGGING=true
